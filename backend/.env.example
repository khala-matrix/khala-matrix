# ── Server ────────────────────────────────────────────────────
PORT=8080
FRONTEND_ORIGIN=http://localhost:3000

# ── Supabase Cloud ────────────────────────────────────────────
# Direct PostgreSQL connection (used by pgx for queries)
# Use keyword/value format to avoid URL-encoding issues with special chars in password:
DATABASE_URL=host=db.[PROJECT_REF].supabase.co port=5432 dbname=postgres user=postgres password=[PASSWORD]
# Or URI format (password must be URL-encoded, e.g. + → %2B, @ → %40):
# DATABASE_URL=postgresql://postgres:[ENCODED_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Project URL (for Auth, Storage, Realtime)
SUPABASE_URL=https://[PROJECT_REF].supabase.co

# Publishable key (sb_ prefix, safe for client-side, respects RLS)
SUPABASE_PUBLISHABLE_KEY=sb_xxxx...

# Secret key (sb_ prefix, bypasses RLS — backend only, never expose to client)
SUPABASE_SECRET_KEY=sb_xxxx...

# ── Upstream: OpenClaw Gateway ─────────────────────────────────
# WebSocket URL (leave empty to disable upstream)
OPENCLAW_GATEWAY_WS_URL=ws://127.0.0.1:18789/v1/gateway/ws
# Access token (from gateway dashboard URL, e.g. http://127.0.0.1:18789/?token=xxx)
OPENCLAW_TOKEN=
# Device identity file path (auto-generated on first run)
DEVICE_IDENTITY_PATH=.khala-device-identity.json
